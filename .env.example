# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/leadfinder?retryWrites=true&w=majority

# Google Cloud APIs
# Obtenha sua chave em: https://console.cloud.google.com/apis/credentials
# APIs necessárias: Geocoding API, Places API, Places API (New)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Opcional: Para busca de Instagram via Google Custom Search
# Crie um Custom Search Engine em: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_CX=your_custom_search_engine_id_here

# Opcional: Instagram Graph API (para buscar dados de perfis)
# Configure em: https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_USER_ID=your_instagram_business_user_id_here
